<?xml version="1.0" encoding="utf-8"?>
<!--
  bottom_sheet_analysis.xml
  Stackable-filter analysis sheet.
  Shows:  filter chips  →  ProgressBar while loading
          →  day-grouped summary table  +  individual transaction cards
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bottom_sheet_bg"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/sheet_handle" />

    <!-- Title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Analysis"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/btn_clear_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clear all"
            android:textColor="#E74C3C"
            android:textSize="13sp"
            android:paddingHorizontal="4dp" />

    </LinearLayout>

    <!-- ============================================================
         ADD-FILTER buttons
         ============================================================ -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="＋ Filter:"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_date_range"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:text="Date range"
                android:textColor="#1a73e8"
                android:textSize="11sp"
                app:cornerRadius="16dp"
                app:strokeColor="#1a73e8" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_desc"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:text="Description"
                android:textColor="#1a73e8"
                android:textSize="11sp"
                app:cornerRadius="16dp"
                app:strokeColor="#1a73e8" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_type"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:text="Type"
                android:textColor="#1a73e8"
                android:textSize="11sp"
                app:cornerRadius="16dp"
                app:strokeColor="#1a73e8" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_amount"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Amount"
                android:textColor="#1a73e8"
                android:textSize="11sp"
                app:cornerRadius="16dp"
                app:strokeColor="#1a73e8" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- ============================================================
         ACTIVE-FILTER CHIPS
         ============================================================ -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_filters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingBottom="2dp"
        app:chipSpacingHorizontal="6dp" />

    <!-- ============================================================
         FILTER PANELS (one visible at a time)
         ============================================================ -->

    <!-- Date range panel -->
    <LinearLayout
        android:id="@+id/panel_date_range"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F0F4FF"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Date Range"
            android:textColor="#1a73e8"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="44dp"
                android:layout_height="wrap_content"
                android:text="From:"
                android:textColor="#555"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_from_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="—"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_pick_from"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pick"
                android:textColor="#009688"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="44dp"
                android:layout_height="wrap_content"
                android:text="To:"
                android:textColor="#555"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_to_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="—"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_pick_to"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pick"
                android:textColor="#009688"
                android:textSize="12sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_apply_date"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:backgroundTint="#1a73e8"
            android:text="Add Date Range Filter"
            android:textColor="@color/white"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Description panel -->
    <LinearLayout
        android:id="@+id/panel_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F0F4FF"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Description Filter"
            android:textColor="#1a73e8"
            android:textSize="13sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:hint="Keyword"
            android:textColorHint="@color/black">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_keyword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@color/black"
                android:textSize="14sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <RadioGroup
            android:id="@+id/rg_desc_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rb_include"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:checked="true"
                android:text="Include matches"
                android:textColor="@color/black"
                android:textSize="12sp" />

            <RadioButton
                android:id="@+id/rb_exclude"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Exclude matches"
                android:textColor="@color/black"
                android:textSize="12sp" />

        </RadioGroup>

        <Button
            android:id="@+id/btn_apply_desc"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:backgroundTint="#1a73e8"
            android:text="Add Description Filter"
            android:textColor="@color/white"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Type panel -->
    <LinearLayout
        android:id="@+id/panel_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F0F4FF"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Transaction Type"
            android:textColor="#1a73e8"
            android:textSize="13sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rg_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rb_credit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="In (credit) only"
                android:textColor="@color/black"
                android:textSize="12sp" />

            <RadioButton
                android:id="@+id/rb_debit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Spent (debit) only"
                android:textColor="@color/black"
                android:textSize="12sp" />

        </RadioGroup>

        <Button
            android:id="@+id/btn_apply_type"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:backgroundTint="#1a73e8"
            android:text="Add Type Filter"
            android:textColor="@color/white"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Amount range panel -->
    <LinearLayout
        android:id="@+id/panel_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F0F4FF"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Amount Range"
            android:textColor="#1a73e8"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:hint="Min ₹"
                android:textColorHint="@color/black">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_min_amount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Max ₹"
                android:textColorHint="@color/black">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_max_amount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <Button
            android:id="@+id/btn_apply_amount"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:backgroundTint="#1a73e8"
            android:text="Add Amount Filter"
            android:textColor="@color/white"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- ============================================================
         LOADER
         ============================================================ -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:visibility="gone" />

    <!-- ============================================================
         RESULTS  (summary table + individual transactions)
         ============================================================ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="420dp"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- No-results message -->
            <TextView
                android:id="@+id/tv_no_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="No transactions match the current filters."
                android:textColor="#999999"
                android:textSize="13sp"
                android:paddingVertical="24dp"
                android:visibility="gone" />

            <!-- Day-grouped summary table (added programmatically) -->
            <LinearLayout
                android:id="@+id/ll_summary_table"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Individual transaction cards (added programmatically) -->
            <LinearLayout
                android:id="@+id/ll_transactions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="4dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Summary bar -->
    <TextView
        android:id="@+id/tv_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:textSize="13sp"
        android:textStyle="bold"
        android:visibility="gone" />

</LinearLayout>